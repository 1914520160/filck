{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Filck",
  "version": "5.0.45",
  "identifier": "com.filck.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Filck",
        "width": 480,
        "height": 700,
        "minWidth": 320,
        "minHeight": 400,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": false,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: asset: http://asset.localhost; script-src 'self' https://esm.sh; connect-src 'self' https://esm.sh ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/1914520160/filck/releases/latest/download/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGQTNBQ0Y5OTIxNjg1RUUKUldUdWhSYVMrYXlqdnptREQvTlpWR1dRckVLVkZaRVBBOGYvQm0wL3FjMjVad1Nkd0ZPUlhSZUMK",
      "windows": {
        "installMode": "passive"
      },
      "active": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "剪贴板管理",
  "version": "5.0.13",
  "identifier": "com.clipboard-manager.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "剪贴板管理 v5.0.13",
        "width": 480,
        "height": 700,
        "minWidth": 320,
        "minHeight": 400,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": false,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; script-src 'self' https://esm.sh; connect-src 'self' https://esm.sh ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.example.com/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY",
      "windows": {
        "installMode": "passive"
      },
      "active": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
